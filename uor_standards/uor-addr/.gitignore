# Rust build artifacts
/target
**/*.rs.bk

# OS artifacts
.DS_Store
Thumbs.db

# Editor scratch
*.swp
*.swo
.vscode/
.idea/

# Claude Code workspace settings
.claude/

# Lake (Lean 4) build artifacts
**/.lake/

# Language-binding build artifacts (regenerated by the release
# workflow / local build scripts; never checked in)
bindings/npm/node_modules/
bindings/npm/dist/
bindings/python/build/
bindings/python/dist/
bindings/python/*.egg-info/
bindings/python/uor_addr/libuor_addr_c.so
bindings/python/uor_addr/libuor_addr_c.dylib
bindings/python/uor_addr/uor_addr_c.dll
bindings/python/uor_addr/__pycache__/

# Python bytecode cache — the tools/ helpers import each other via importlib.
__pycache__/
*.pyc

# Pinned external models — downloaded on demand by the live V&V tests
# (UOR_ADDR_LIVE=1); cached here, never checked in (multi-hundred-MB).
crates/uor-addr/tests/fixtures/models/*.gguf
crates/uor-addr/tests/fixtures/models/*.onnx
