{
  "name": "Categorical X",
  "features": {
    "ghcr.io/devcontainers/features/rust:1": {},
    "ghcr.io/guiyomh/features/just:0": {},
    "ghcr.io/lumenpink/devcontainer-features/wasm-pack:0": {},
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.12"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    },
    "ghcr.io/devcontainers-contrib/features/apt-packages:1": {
      "packages": "patchelf,gcc-aarch64-linux-gnu"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "anthropic.claude-code",
        "leanprover.lean4"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "[rust]": {
          "editor.defaultFormatter": "rust-lang.rust-analyzer"
        },
        "rust-analyzer.check.command": "clippy",
        "rust-analyzer.procMacro.enable": true,
        "rust-analyzer.cargo.allFeatures": true,
        "search.exclude": {
          "**/target": true
        },
        "files.watcherExclude": {
          "**/target/**": true
        }
      }
    }
  },
  "remoteEnv": {
    "PATH": "/home/codespace/.elan/bin:/home/codespace/.cargo/bin:${containerEnv:PATH}"
  },
  "postCreateCommand": "bash -c 'set -euxo pipefail; curl https://elan.lean-lang.org/elan-init.sh -sSf | sh -s -- -y --default-toolchain none; rustup target add wasm32-wasip2 thumbv7em-none-eabihf; pip install --user --upgrade pip build wheel auditwheel twine; cargo install --locked cbindgen || true'"
}
