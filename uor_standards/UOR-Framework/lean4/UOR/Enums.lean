  | .sub => false
  | .mul => false
  | .xor => false
  | .and => false
  | .or => false
  | .le => false
  | .lt => false
  | .ge => false
  | .gt => false
  | .concat => false
  | .div => false
  | .mod => false
  | .pow => false

/-- The geometric character of this operation. -/
def hasGeometricCharacter : PrimitiveOp → GeometricCharacter
  | .neg => .ringReflection
  | .bnot => .hypercubeReflection
  | .succ => .rotation
  | .pred => .rotationInverse
  | .add => .translation
  | .sub => .translation
  | .mul => .scaling
  | .xor => .hypercubeTranslation
  | .and => .hypercubeProjection
  | .or => .hypercubeJoin
  | .le => .constraintSelection
  | .lt => .constraintSelection
  | .ge => .constraintSelection
  | .gt => .constraintSelection
  | .concat => .hypercubeJoin
  | .div => .quotient
  | .mod => .remainder
  | .pow => .iteratedScaling

end PrimitiveOp

