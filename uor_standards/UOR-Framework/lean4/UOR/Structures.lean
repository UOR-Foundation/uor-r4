namespace UOR.User.Type_

/-- An ordered composition of WittLift steps from liftSourceLevel (Q_j) to liftTargetLevel (Q_k) for any j < k. The canonical object certifying type completeness at arbitrary Q_k. -/
structure LiftChain (P : Primitives) where
  /-- The quantum level at the base of the chain. -/
  liftSourceLevel : Option WittLevel
  /-- The number of WittLift steps in the chain (k - j). -/
  chainLength : Option P.NonNegativeInteger
  /-- A WittLift step in this chain. Non-functional: one per step. -/
  chainStep : Array (WittLift P)
  /-- The full obstruction history of this chain. -/
  chainObstructionProfile : Option (ObstructionChain P)
  /-- The basis size of the CompleteType at the chain target level. -/
  resolvedBasisSize : Option P.NonNegativeInteger

instance : Inhabited (LiftChain UOR.Prims.Standard) where
  default := {
    liftSourceLevel := none
    chainLength := none
    chainStep := #[]
    chainObstructionProfile := none
    resolvedBasisSize := none
  }

end UOR.User.Type_

namespace UOR.Bridge.Cert

/-- A kernel-issued certificate attesting that a LiftChain from liftSourceLevel to liftTargetLevel is complete. -/
structure LiftChainCertificate (P : Primitives) extends Certificate P where
  /-- The LiftChain this certificate attests to. -/
  certifiedChain : Option (UOR.User.Type_.LiftChain P)
  /-- The ordered per-step evidence for this certificate. -/
  chainAuditTrail : Option (ChainAuditTrail P)
  /-- The quantum level Q_k at which the certificate was issued. -/
  targetLevel : Option WittLevel
  /-- The quantum level Q_j from which the tower was started. -/
  sourceLevel : Option WittLevel

instance : Inhabited (LiftChainCertificate UOR.Prims.Standard) where
  default := {
    certifiedChain := none
    chainAuditTrail := none
    targetLevel := none
    sourceLevel := none
    method := none
    verified := none
    wittLength := none
    timestamp := none
    certifies := none
  }

end UOR.Bridge.Cert

namespace UOR.Bridge.Resolver

/-- A Resolver that constructs a LiftChain from liftSourceLevel to an arbitrary liftTargetLevel Q_k by iterating IncrementalCompletenessResolver step by step. -/
structure TowerCompletenessResolver (P : Primitives) extends Resolver P where
  /-- The level at which the tower starts. -/
  towerSourceLevel : Option WittLevel
  /-- The level to which the tower is being built. -/
  towerTargetLevel : Option WittLevel
  /-- The LiftChain under construction. -/
  currentChain : Option (UOR.User.Type_.LiftChain P)
  /-- The IncrementalCompletenessResolver used for each single-step lift. -/
  towerStepResolver : Option (IncrementalCompletenessResolver P)

instance : Inhabited (TowerCompletenessResolver UOR.Prims.Standard) where
  default := {
    towerSourceLevel := none
    towerTargetLevel := none
    currentChain := none
    towerStepResolver := none
    inputType := none
    outputType := none
    strategy := none
    resolutionState := none
    hasComplexityClass := none
    dispatchTable := none
    resolverPredicate := none
  }

end UOR.Bridge.Resolver
